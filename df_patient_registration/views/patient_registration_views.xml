<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_patient_registration_tree" model="ir.ui.view">
        <field name="name">df.patient.registration.tree</field>
        <field name="model">df.patient.registration</field>
        <field name="arch" type="xml">
            <tree>
                <field name="display_name"/>
                <field name="state"/>
                <field name="institution_system"/>
                <field name="unicodigo"/>
                <field name="sex"/>
                <field name="age"/>
                <field name="sheet_number"/>
            </tree>
        </field>
    </record>

    <record id="view_df_patient_registration_form" model="ir.ui.view">
        <field name="name">df.patient.registration.form</field>
        <field name="model">df.patient.registration</field>
        <field name="arch" type="xml">
            <form string="Registro de Paciente">
                <header>
                    <button type="object"
                            name="action_set_state_draft"
                            string="Borrador"
                            class="btn btn-secondary"
                            attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    <button type="object"
                            name="action_set_state_active"
                            string="Activar"
                            class="btn btn-primary"
                            attrs="{'invisible': [('state', '=', 'active')]}"/>
                    <button type="object"
                            name="action_set_state_archived"
                            string="Archivar"
                            class="btn btn-secondary"
                            attrs="{'invisible': [('state', '=', 'archived')]}"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,active,archived"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="display_name" readonly="1" nolabel="1"/>
                        </h1>
                    </div>
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_partner"
                                class="oe_stat_button"
                                attrs="{'invisible': [('partner_id', '=', False)]}"
                                icon="fa-user">
                            <field name="partner_id" string="Contacto" widget="statinfo"/>
                        </button>
                        <button type="object"
                                name="action_open_partner_invoices"
                                class="oe_stat_button"
                                attrs="{'invisible': [('partner_invoice_count', '=', 0)]}"
                                icon="fa-file-text-o">
                            <field name="partner_invoice_count" string="Facturas" widget="statinfo"/>
                        </button>
                    </div>

                    <group string="A. Datos del establecimiento y usuario / paciente">
                        <group>
                            <field name="identification"/>
                            <field name="address"/>
                            <field name="institution_system"/>
                            <field name="unicodigo"/>
                            <field name="unique_clinical_history_number"/>
                        </group>
                        <group>
                            <field name="first_lastname"/>
                            <field name="second_lastname"/>
                            <field name="first_name"/>
                            <field name="second_name"/>
                            <field name="sex"/>
                            <field name="age"/>
                        </group>
                    </group>

                    <group string="B. Motivo de consulta">
                        <group>
                            <field name="consultation_reason"/>
                            <field name="pregnant"/>
                        </group>
                    </group>

                    <group string="C. Enfermedad actual">
                        <field name="current_illness"/>
                    </group>

                    <group string="D. Antecedentes patológicos personales">
                        <group>
                            <field name="personal_no_refiere"/>
                        </group>

                        <group col="2" attrs="{'invisible': [('personal_no_refiere', '=', True)]}">
                            <group>
                                <field name="personal_antibiotic_allergy"/>
                                <field name="personal_anesthesia_allergy"/>
                                <field name="personal_hemorrhages"/>
                                <field name="personal_hiv_aids"/>
                                <field name="personal_tuberculosis"/>
                            </group>
                            <group>
                                <field name="personal_asthma"/>
                                <field name="personal_diabetes"/>
                                <field name="personal_hypertension"/>
                                <field name="personal_heart_disease"/>
                                <field name="personal_other"/>
                            </group>
                        </group>
                        <field name="personal_observaciones" attrs="{'invisible': [('personal_no_refiere', '=', True)]}"/>
                    </group>

                    <group string="E. Antecedentes patológicos familiares">
                        <group>
                            <field name="family_no_refiere"/>
                        </group>

                        <group col="2" attrs="{'invisible': [('family_no_refiere', '=', True)]}">
                            <group>
                                <field name="family_cardiopathy"/>
                                <field name="family_hypertension"/>
                                <field name="family_vascular_disease"/>
                                <field name="family_endocrine_metabolic"/>
                                <field name="family_cancer"/>
                            </group>
                            <group>
                                <field name="family_tuberculosis"/>
                                <field name="family_mental_illness"/>
                                <field name="family_infectious_disease"/>
                                <field name="family_malformation"/>
                                <field name="family_other"/>
                            </group>
                        </group>
                        <field name="family_observaciones" attrs="{'invisible': [('family_no_refiere', '=', True)]}"/>
                    </group>

                    <group string="F. Constantes vitales">
                        <group>
                            <field name="temperature"/>
                            <field name="pulse"/>
                        </group>
                        <group>
                            <field name="respiratory_rate"/>
                            <field name="blood_pressure"/>
                        </group>
                    </group>

                    <group string="G. Examen del sistema estomatognático">
                        <group>
                            <field name="exam_lips"/>
                            <field name="exam_cheeks"/>
                            <field name="exam_upper_jaw"/>
                            <field name="exam_lower_jaw"/>
                            <field name="exam_tongue"/>
                            <field name="exam_palate"/>
                            <field name="exam_floor_of_mouth"/>
                        </group>
                        <group>
                            <field name="exam_cheeks_inner"/>
                            <field name="exam_salivary_glands"/>
                            <field name="exam_oropharynx"/>
                            <field name="exam_atm"/>
                            <field name="exam_ganglia"/>
                            <field name="exam_others"/>
                        </group>
                        <field name="affected_region_description"/>
                    </group>

                    <group string="Adjuntos clínicos (imágenes)">
                        <field name="patient_image_attachment_ids"
                               widget="many2many_binary"
                               domain="[('mimetype', 'ilike', 'image/%')]"
                               options="{'no_create': True}"/>
                    </group>

                    <notebook>
                        <page string="P. Tratamiento">
                            <field name="treatment_line_ids" nolabel="1">
                                <tree editable="bottom">
                                    <field name="session_number"/>
                                    <field name="date"/>
                                    <field name="diagnosis_complications"/>
                                    <field name="procedures"/>
                                    <field name="prescriptions"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field
                            name="message_follower_ids"
                            widget="mail_followers"
                            help="Follow this salesteam to automatically track the events associated to users of this team."
                    />
                    <field name="message_ids" widget="mail_thread"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_df_patient_registration_search" model="ir.ui.view">
        <field name="name">df.patient.registration.search</field>
        <field name="model">df.patient.registration</field>
        <field name="arch" type="xml">
            <search>
                <field name="display_name"/>
                <field name="first_name"/>
                <field name="first_lastname"/>
                <field name="unicodigo"/>
                <filter name="filter_active" string="Activos" domain="[('active', '=', True)]"/>
            </search>
        </field>
    </record>

    <record id="action_df_patient_registration" model="ir.actions.act_window">
        <field name="name">Pacientes</field>
        <field name="res_model">df.patient.registration</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_df_patient_registration_search"/>
    </record>

    <menuitem id="menu_df_patient_root" name="Clínica"/>
    <menuitem id="menu_df_patient_registration" name="Pacientes" parent="menu_df_patient_root"
              action="action_df_patient_registration"/>
</odoo>
