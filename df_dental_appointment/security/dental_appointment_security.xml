<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_df_dental_receptionist" model="res.groups">
        <field name="name">Recepción dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_df_dental_dentist" model="res.groups">
        <field name="name">Odontólogo</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_df_dental_manager" model="res.groups">
        <field name="name">Gestor clínica dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_df_dental_receptionist')), (4, ref('group_df_dental_dentist'))]"/>
    </record>

    <record id="rule_df_dental_appointment_manager_all" model="ir.rule">
        <field name="name">Citas dental: gestor ve todas</field>
        <field name="model_id" ref="model_df_dental_appointment"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_df_dental_manager'))]"/>
    </record>
    <record id="rule_df_dental_appointment_dentist_own" model="ir.rule">
        <field name="name">Citas dental: odontólogo ve las propias</field>
        <field name="model_id" ref="model_df_dental_appointment"/>
        <field name="domain_force">[('dentist_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_df_dental_dentist'))]"/>
    </record>
</odoo>
