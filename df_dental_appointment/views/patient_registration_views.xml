<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_patient_registration_form_dental_appointment" model="ir.ui.view">
        <field name="name">df.patient.registration.form.dental.appointment</field>
        <field name="model">df.patient.registration</field>
        <field name="inherit_id" ref="df_patient_registration.view_df_patient_registration_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_open_dental_appointments"
                        class="oe_stat_button"
                        icon="fa-calendar">
                    <field name="dental_appointment_count" string="Citas" widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
