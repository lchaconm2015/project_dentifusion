<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_dental_appointment_tree" model="ir.ui.view">
        <field name="name">df.dental.appointment.tree</field>
        <field name="model">df.dental.appointment</field>
        <field name="arch" type="xml">
            <tree string="Citas" decoration-muted="state=='cancelled'" decoration-danger="state=='no_show'">
                <field name="sequence_code"/>
                <field name="start_datetime"/>
                <field name="patient_id"/>
                <field name="dentist_id"/>
                <field name="appointment_type"/>
                <field name="specialty_id"/>
                <field name="state"/>
                <field name="duration" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="view_df_dental_appointment_form" model="ir.ui.view">
        <field name="name">df.dental.appointment.form</field>
        <field name="model">df.dental.appointment</field>
        <field name="arch" type="xml">
            <form string="Cita odontológica">
                <header>
                    <button name="action_confirm" string="Confirmar" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_check_in" string="Check-in" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'not in', ('draft', 'confirmed'))]}"/>
                    <button name="action_start" string="Iniciar cita" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'not in', ('confirmed', 'checked_in'))]}"/>
                    <button name="action_mark_done" string="Marcar realizada" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('confirmed', 'checked_in', 'in_progress'))]}"/>
                    <button name="action_no_show" string="No asistió" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ('done', 'cancelled', 'no_show'))]}"/>
                    <button name="action_cancel" string="Cancelar" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ('done', 'cancelled'))]}"/>
                    <button name="action_reset_draft" string="Volver a borrador" type="object" groups="df_dental_appointment.group_df_dental_manager"
                            attrs="{'invisible': [('state', '=', 'draft')]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,checked_in,in_progress,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="sequence_code" class="oe_edit_only"/>
                        <h1><field name="sequence_code" readonly="1"/></h1>
                        <field name="name" readonly="1" nolabel="1" class="text-muted"/>
                    </div>
                    <group>
                        <group string="Agenda">
                            <field name="patient_id" options="{'no_create_edit': True}"/>
                            <field name="partner_id"/>
                            <field name="dentist_id"/>
                            <field name="assistant_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Horario">
                            <field name="start_datetime"/>
                            <field name="end_datetime"/>
                            <field name="duration" readonly="1"/>
                            <field name="appointment_date" readonly="1"/>
                        </group>
                    </group>
                    <group string="Tipo y recursos">
                        <group>
                            <field name="appointment_type"/>
                            <field name="type_template_id"/>
                            <field name="specialty_id"/>
                        </group>
                        <group>
                            <field name="chair_id"/>
                            <field name="room_id"/>
                            <field name="color"/>
                        </group>
                    </group>
                    <group string="Administrativo">
                        <group>
                            <field name="checkin_datetime"/>
                            <field name="checkout_datetime"/>
                            <field name="attendance_status"/>
                        </group>
                        <group>
                            <field name="contact_phone"/>
                            <field name="contact_email"/>
                            <field name="referred_by"/>
                        </group>
                    </group>
                    <group name="df_dental_appointment_notes" string="Notas">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                    <group string="Cancelación" attrs="{'invisible': [('state', '!=', 'cancelled')]}">
                        <field name="cancel_reason" nolabel="1" colspan="2"/>
                    </group>
                    <group>
                        <field name="calendar_event_id" readonly="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_df_dental_appointment_kanban" model="ir.ui.view">
        <field name="name">df.dental.appointment.kanban</field>
        <field name="model">df.dental.appointment</field>
        <field name="arch" type="xml">
            <!-- Etapas: Nuevas (borrador) | Confirmadas (resto activo) | Canceladas/finalizadas -->
            <kanban default_group_by="kanban_lane"
                    class="o_kanban_small_column"
                    quick_create="false"
                    create="true"
                    records_draggable="0">
                <field name="id"/>
                <field name="kanban_lane"/>
                <field name="sequence_code"/>
                <field name="patient_id"/>
                <field name="dentist_id"/>
                <field name="start_datetime"/>
                <field name="appointment_type"/>
                <field name="specialty_id"/>
                <field name="state"/>
                <field name="color"/>
                <field name="activity_ids"/>
                <templates>
                    <t t-name="kanban-menu">
                        <t t-if="widget.editable"><a role="menuitem" type="edit" class="dropdown-item">Editar</a></t>
                        <t t-if="widget.deletable"><a role="menuitem" type="delete" class="dropdown-item">Eliminar</a></t>
                        <ul class="oe_kanban_colorpicker" data-field="color"/>
                    </t>
                    <t t-name="kanban-box">
                        <div t-attf-class="#{!selection_mode ? kanban_color(record.color.raw_value) : ''} oe_kanban_global_click oe_kanban_card d-flex flex-column">
                            <div class="oe_kanban_content flex-grow-1">
                                <div class="o_kanban_record_top mb-1">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="sequence_code"/>
                                        </strong>
                                    </div>
                                </div>
                                <div class="o_kanban_record_body">
                                    <div class="fw-bold">
                                        <field name="patient_id"/>
                                    </div>
                                    <div class="text-muted small">
                                        <i class="fa fa-clock-o" title="Horario"/>
                                        <field name="start_datetime" widget="datetime"/>
                                    </div>
                                    <div class="small">
                                        <field name="dentist_id" widget="many2one_avatar_user"/>
                                    </div>
                                    <div class="small text-muted">
                                        <field name="state"/>
                                    </div>
                                    <div class="small text-muted" t-if="record.appointment_type.raw_value">
                                        <field name="appointment_type"/>
                                    </div>
                                    <div class="small text-muted" t-if="record.specialty_id.raw_value">
                                        <field name="specialty_id"/>
                                    </div>
                                </div>
                                <div class="o_kanban_record_bottom mt-1">
                                    <div class="oe_kanban_bottom_left">
                                        <field name="activity_ids" widget="kanban_activity"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_df_dental_appointment_calendar" model="ir.ui.view">
        <field name="name">df.dental.appointment.calendar</field>
        <field name="model">df.dental.appointment</field>
        <field name="arch" type="xml">
            <!-- Odoo 16: quick_add. Odoo 17+: usar quick_create en su lugar -->
            <calendar string="Agenda dental" date_start="start_datetime" date_stop="end_datetime"
                      color="dentist_id" mode="week" quick_add="false">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="state"/>
            </calendar>
        </field>
    </record>

    <record id="view_df_dental_appointment_search" model="ir.ui.view">
        <field name="name">df.dental.appointment.search</field>
        <field name="model">df.dental.appointment</field>
        <field name="arch" type="xml">
            <search string="Citas">
                <field name="sequence_code"/>
                <field name="patient_id"/>
                <field name="dentist_id"/>
                <field name="specialty_id"/>
                <filter name="filter_today" string="Hoy" domain="[('appointment_date', '=', context_today())]"/>
                <filter name="filter_tomorrow" string="Mañana"
                        domain="[('appointment_date', '=', context_today() + relativedelta(days=1))]"/>
                <separator/>
                <filter name="filter_confirmed" string="Confirmadas" domain="[('state', '=', 'confirmed')]"/>
                <filter name="filter_in_progress" string="En curso" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_no_show" string="No asistió" domain="[('state', '=', 'no_show')]"/>
                <filter name="filter_cancelled" string="Canceladas" domain="[('state', '=', 'cancelled')]"/>
                <separator/>
                <filter name="filter_my" string="Mis citas" domain="[('dentist_id', '=', uid)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_kanban_lane" string="Etapa (Kanban)" context="{'group_by': 'kanban_lane'}"/>
                    <filter name="group_dentist" string="Odontólogo" context="{'group_by': 'dentist_id'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_type" string="Tipo" context="{'group_by': 'appointment_type'}"/>
                    <filter name="group_date" string="Fecha" context="{'group_by': 'appointment_date'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_df_dental_appointment" model="ir.actions.act_window">
        <field name="name">Todas las citas</field>
        <field name="res_model">df.dental.appointment</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="domain">[]</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Cree una nueva cita odontológica.</p>
        </field>
    </record>

    <record id="action_df_dental_appointment_calendar_only" model="ir.actions.act_window">
        <field name="name">Calendario</field>
        <field name="res_model">df.dental.appointment</field>
        <field name="view_mode">calendar,kanban,tree,form</field>
    </record>

    <record id="action_df_dental_appointment_today" model="ir.actions.act_window">
        <field name="name">Citas de hoy</field>
        <field name="res_model">df.dental.appointment</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="domain">[('appointment_date', '=', context_today())]</field>
    </record>

    <record id="action_df_dental_appointment_my" model="ir.actions.act_window">
        <field name="name">Mis citas</field>
        <field name="res_model">df.dental.appointment</field>
        <field name="view_mode">kanban,tree,form,calendar</field>
        <field name="domain">[('dentist_id', '=', uid)]</field>
    </record>
</odoo>
