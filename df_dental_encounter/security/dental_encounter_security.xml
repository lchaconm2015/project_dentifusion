<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_df_dental_clinical_assistant" model="res.groups">
        <field name="name">Asistente clínico dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_df_dental_clinical_manager" model="res.groups">
        <field name="name">Gestor clínico dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_df_dental_clinical_assistant')), (4, ref('df_dental_appointment.group_df_dental_manager'))]"/>
    </record>

    <record id="rule_df_dental_encounter_manager_all" model="ir.rule">
        <field name="name">Encuentro: gestor clínico ve todos</field>
        <field name="model_id" ref="model_df_dental_encounter"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_df_dental_clinical_manager'))]"/>
    </record>
    <record id="rule_df_dental_encounter_dentist_own" model="ir.rule">
        <field name="name">Encuentro: odontólogo ve los propios</field>
        <field name="model_id" ref="model_df_dental_encounter"/>
        <field name="domain_force">[('dentist_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('df_dental_appointment.group_df_dental_dentist'))]"/>
    </record>

    <record id="df_dental_appointment.menu_df_dental_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [
            ref('df_dental_appointment.group_df_dental_receptionist'),
            ref('df_dental_appointment.group_df_dental_dentist'),
            ref('df_dental_appointment.group_df_dental_manager'),
            ref('df_dental_encounter.group_df_dental_clinical_assistant'),
            ref('df_dental_encounter.group_df_dental_clinical_manager'),
        ])]"/>
    </record>
</odoo>
