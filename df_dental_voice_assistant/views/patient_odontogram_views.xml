<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_patient_odontogram_form_inherit_voice" model="ir.ui.view">
        <field name="name">df.patient.odontogram.form.inherit.voice</field>
        <field name="model">df.patient.odontogram</field>
        <field name="inherit_id" ref="df_patient_odontogram.view_df_patient_odontogram_form"/>
