<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_dental_voice_session_tree" model="ir.ui.view">
        <field name="name">df.dental.voice.session.tree</field>
        <field name="model">df.dental.voice.session</field>
        <field name="arch" type="xml">
            <tree string="Sesiones de voz">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="encounter_id"/>
                <field name="channel"/>
                <field name="dentist_id"/>
                <field name="state"/>
                <field name="start_datetime"/>
                <field name="event_count"/>
            </tree>
        </field>
    </record>

    <record id="view_df_dental_voice_session_form" model="ir.ui.view">
        <field name="name">df.dental.voice.session.form</field>
        <field name="model">df.dental.voice.session</field>
        <field name="arch" type="xml">
            <form string="Sesión de voz">
                <header>
                    <button name="action_start" string="Iniciar" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('draft', 'paused'))]}"/>
                    <button name="action_pause" string="Pausar" type="object" attrs="{'invisible': [('state', '!=', 'active')]}"/>
                    <button name="action_resume" string="Reanudar" type="object" attrs="{'invisible': [('state', '!=', 'paused')]}"/>
                    <button name="action_complete" string="Completar" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('active', 'paused', 'draft'))]}"/>
                    <button name="action_cancel" string="Cancelar" type="object" attrs="{'invisible': [('state', 'in', ('completed', 'cancelled'))]}"/>
                    <button name="action_open_encounter" string="Encuentro" type="object"
                            attrs="{'invisible': [('encounter_id', '=', False)]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,paused,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Contexto">
                            <field name="patient_id" options="{'no_create_edit': True}"/>
                            <field name="encounter_id" options="{'no_create_edit': True}"/>
                            <field name="appointment_id" options="{'no_create_edit': True}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Equipo y canal">
                            <field name="dentist_id"/>
                            <field name="assistant_id"/>
                            <field name="channel"/>
                            <field name="device_name"/>
                            <field name="external_session_ref"/>
                        </group>
                    </group>
                    <group string="Resumen">
                        <field name="start_datetime"/>
                        <field name="end_datetime"/>
                        <field name="event_count"/>
                        <field name="processed_event_count"/>
                        <field name="error_event_count"/>
                    </group>
                    <group string="Notas">
                        <field name="notes" nolabel="1" colspan="2"/>
                    </group>
                    <notebook>
                        <page string="Eventos" name="events">
                            <field name="event_ids" context="{'default_session_id': active_id}">
                                <tree string="Eventos" editable="bottom">
                                    <field name="name" readonly="1"/>
                                    <field name="source_type"/>
                                    <field name="raw_text"/>
                                    <field name="intent"/>
                                    <field name="confidence_score"/>
                                    <field name="execution_status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_df_dental_voice_session_search" model="ir.ui.view">
        <field name="name">df.dental.voice.session.search</field>
        <field name="model">df.dental.voice.session</field>
        <field name="arch" type="xml">
            <search string="Sesiones de voz">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="encounter_id"/>
                <field name="dentist_id"/>
                <filter name="active_sessions" string="Activas" domain="[('state', '=', 'active')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_patient" string="Paciente" context="{'group_by': 'patient_id'}"/>
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_channel" string="Canal" context="{'group_by': 'channel'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_df_dental_voice_session" model="ir.actions.act_window">
        <field name="name">Sesiones de voz</field>
        <field name="res_model">df.dental.voice.session</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Inicie una sesión desde un encuentro clínico o regístrela aquí.</p>
        </field>
    </record>
</odoo>
