<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_company_form_inherit_dental_voice" model="ir.ui.view">
        <field name="name">res.company.form.inherit.dental.voice</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Asistente voz dental" name="dental_voice" groups="df_dental_encounter.group_df_dental_clinical_manager">
                    <group string="General">
                        <field name="voice_assistant_enabled"/>
                        <field name="voice_auto_confirm"/>
                        <field name="voice_store_audio"/>
                        <field name="voice_default_channel"/>
                    </group>
                    <group string="Políticas clínicas">
                        <field name="voice_require_encounter"/>
                        <field name="voice_allow_plan_creation"/>
                        <field name="voice_allow_procedure_creation"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
