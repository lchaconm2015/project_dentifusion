<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_df_dental_voice_user" model="res.groups">
        <field name="name">Usuario asistente de voz dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('df_dental_encounter.group_df_dental_clinical_assistant'))]"/>
    </record>
    <record id="group_df_dental_voice_manager" model="res.groups">
        <field name="name">Gestor asistente de voz dental</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_df_dental_voice_user')), (4, ref('df_dental_encounter.group_df_dental_clinical_manager'))]"/>
    </record>

    <record id="rule_df_dental_voice_session_manager" model="ir.rule">
        <field name="name">Sesión voz: gestor clínico ve todas</field>
        <field name="model_id" ref="model_df_dental_voice_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('df_dental_encounter.group_df_dental_clinical_manager'))]"/>
    </record>
    <record id="rule_df_dental_voice_session_dentist" model="ir.rule">
        <field name="name">Sesión voz: odontólogo ve propias</field>
        <field name="model_id" ref="model_df_dental_voice_session"/>
        <field name="domain_force">[('dentist_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('df_dental_appointment.group_df_dental_dentist'))]"/>
    </record>

    <record id="rule_df_dental_voice_event_manager" model="ir.rule">
        <field name="name">Evento voz: gestor ve todos</field>
        <field name="model_id" ref="model_df_dental_voice_event"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('df_dental_encounter.group_df_dental_clinical_manager'))]"/>
    </record>
    <record id="rule_df_dental_voice_event_dentist" model="ir.rule">
        <field name="name">Evento voz: odontólogo ve propios</field>
        <field name="model_id" ref="model_df_dental_voice_event"/>
        <field name="domain_force">[('session_id.dentist_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('df_dental_appointment.group_df_dental_dentist'))]"/>
    </record>
</odoo>
