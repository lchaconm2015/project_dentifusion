<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Sesiones de voz (Alexa): modelo persistente + chatter -->

    <record id="view_dental_voice_session_wizard_tree" model="ir.ui.view">
        <field name="name">dental.voice.session.tree</field>
        <field name="model">dental.voice.session</field>
        <field name="arch" type="xml">
            <tree string="Sesiones de voz" create="1" edit="1">
                <field name="create_date" string="Recibido"/>
                <field name="name"/>
                <field name="patient_name"/>
                <field name="alexa_session_id"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'in_progress'"
                       decoration-success="state == 'done'"
                       decoration-muted="state == 'cancel'"/>
                <field name="started_at"/>
                <field name="active" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_dental_voice_session_wizard_form" model="ir.ui.view">
        <field name="name">dental.voice.session.form</field>
        <field name="model">dental.voice.session</field>
        <field name="arch" type="xml">
            <form string="Sesión de voz (Alexa)">
                <header>
                    <button name="action_start_session" type="object" string="Iniciar sesión"
                            class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('draft',))]}"/>
                    <button name="action_save_session" type="object" string="Marcar como guardada"
                            class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ('done', 'cancel'))]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,in_progress,done,cancel"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" class="oe_edit_only"/>
                        <h1>
                            <field name="name" placeholder="Referencia de sesión"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Alexa / paciente">
                            <field name="alexa_session_id" readonly="1"/>
                            <field name="patient_name"/>
                            <field name="partner_id"/>
                            <field name="started_at"/>
                            <field name="active"/>
                        </group>
                        <group string="Resumen">
                            <field name="summary_text" nolabel="1" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Hallazgos (Alexa)" name="lines">
                            <field name="line_ids" nolabel="1">
                                <tree string="Hallazgos" editable="bottom" create="1" delete="1">
                                    <field name="sequence" widget="handle"/>
                                    <field name="tooth_code"/>
                                    <field name="surface"/>
                                    <field name="finding"/>
                                    <field name="raw_payload" optional="show"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter>
                    <field name="message_follower_ids" widget="mail_followers"/>
                    <field name="activity_ids" widget="mail_activity"/>
                    <field name="message_ids" widget="mail_thread"/>
                </chatter>
            </form>
        </field>
    </record>

    <record id="view_dental_voice_session_wizard_search" model="ir.ui.view">
        <field name="name">dental.voice.session.search</field>
        <field name="model">dental.voice.session</field>
        <field name="arch" type="xml">
            <search string="Sesiones de voz">
                <field name="name"/>
                <field name="patient_name"/>
                <field name="alexa_session_id"/>
                <filter name="filter_in_progress" string="En progreso" domain="[('state', '=', 'in_progress')]"/>
                <filter name="filter_draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="filter_done" string="Guardadas" domain="[('state', '=', 'done')]"/>
                <separator/>
                <filter name="filter_active" string="Activas" domain="[('active', '=', True)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_state" string="Estado" context="{'group_by': 'state'}"/>
                    <filter name="group_create_date" string="Fecha creación" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_dental_voice_session_wizard" model="ir.actions.act_window">
        <field name="name">Sesiones de voz (Alexa)</field>
        <field name="res_model">dental.voice.session</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_dental_voice_session_wizard_search"/>
        <field name="context">{'active_test': False}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aún no hay sesiones de voz registradas.
            </p>
            <p>
                Las sesiones creadas por Alexa se guardan de forma persistente (historial clínico / auditoría).
            </p>
        </field>
    </record>

    <menuitem id="menu_df_dental_voice_sessions"
              name="Sesiones de voz (Alexa)"
              parent="df_patient_registration.menu_df_patient_root"
              action="action_dental_voice_session_wizard"
              sequence="25"/>
</odoo>
