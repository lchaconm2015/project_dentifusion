<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="group_df_dental_treatment_user" model="res.groups">
        <field name="name">Usuario planes de tratamiento</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
    <record id="group_df_dental_treatment_manager" model="res.groups">
        <field name="name">Gestor planes de tratamiento</field>
        <field name="category_id" ref="base.module_category_services"/>
        <field name="implied_ids" eval="[(4, ref('group_df_dental_treatment_user')), (4, ref('df_dental_encounter.group_df_dental_clinical_manager'))]"/>
    </record>

    <record id="df_dental_appointment.menu_df_dental_root" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [
            ref('df_dental_appointment.group_df_dental_receptionist'),
            ref('df_dental_appointment.group_df_dental_dentist'),
            ref('df_dental_appointment.group_df_dental_manager'),
            ref('df_dental_encounter.group_df_dental_clinical_assistant'),
            ref('df_dental_encounter.group_df_dental_clinical_manager'),
            ref('df_dental_treatment_plan.group_df_dental_treatment_user'),
            ref('df_dental_treatment_plan.group_df_dental_treatment_manager'),
        ])]"/>
    </record>
</odoo>
