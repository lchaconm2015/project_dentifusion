<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_patient_registration_form_treatment_plan" model="ir.ui.view">
        <field name="name">df.patient.registration.form.treatment.plan</field>
        <field name="model">df.patient.registration</field>
        <field name="inherit_id" ref="df_patient_registration.view_df_patient_registration_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object" name="action_open_dental_treatment_plans" class="oe_stat_button" icon="fa-list-alt">
                    <field name="dental_treatment_plan_count" string="Planes trat." widget="statinfo"/>
                </button>
            </xpath>
        </field>
    </record>
</odoo>
