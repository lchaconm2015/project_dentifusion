<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_dental_treatment_plan_tree" model="ir.ui.view">
        <field name="name">df.dental.treatment.plan.tree</field>
        <field name="model">df.dental.treatment.plan</field>
        <field name="arch" type="xml">
            <tree string="Planes de tratamiento" decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="plan_date"/>
                <field name="patient_id"/>
                <field name="dentist_id"/>
                <field name="state"/>
                <field name="estimated_amount"/>
                <field name="progress_percent" optional="show"/>
                <field name="encounter_id" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_df_dental_treatment_plan_form" model="ir.ui.view">
        <field name="name">df.dental.treatment.plan.form</field>
        <field name="model">df.dental.treatment.plan</field>
        <field name="arch" type="xml">
            <form string="Plan de tratamiento">
                <header>
                    <button name="action_propose" string="Enviar / Proponer" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_partial_accept" string="Aceptación parcial" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'not in', ('proposed', 'draft'))]}"/>
                    <button name="action_accept" string="Marcar aceptado" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('proposed', 'partially_accepted', 'draft'))]}"/>
                    <button name="action_reject" string="Rechazar plan" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ('completed', 'cancelled', 'rejected'))]}"/>
                    <button name="action_start_execution" string="Iniciar ejecución" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('accepted', 'partially_accepted'))]}"/>
                    <button name="action_complete" string="Completar plan" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', '!=', 'in_progress')]}"/>
                    <button name="action_cancel" string="Cancelar plan" type="object" class="btn-secondary"
                            groups="df_dental_treatment_plan.group_df_dental_treatment_manager"
                            attrs="{'invisible': [('state', 'in', ('completed', 'cancelled'))]}"/>
                    <button name="action_reset_draft" string="Volver a borrador" type="object"
                            groups="df_dental_treatment_plan.group_df_dental_treatment_manager"
                            attrs="{'invisible': [('state', 'not in', ('cancelled', 'rejected', 'proposed'))]}"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,proposed,partially_accepted,accepted,in_progress,completed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="patient_id" options="{'no_create_edit': True}"/>
                            <field name="partner_id"/>
                            <field name="dentist_id"/>
                            <field name="encounter_id" options="{'no_create_edit': True}"/>
                            <field name="appointment_id" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Fechas y moneda">
                            <field name="plan_date"/>
                            <field name="valid_until"/>
                            <field name="currency_id"/>
                            <field name="estimated_amount" readonly="1"/>
                            <field name="accepted_amount" readonly="1"/>
                            <field name="executed_amount" readonly="1"/>
                            <field name="progress_percent" readonly="1"/>
                        </group>
                    </group>
                    <group string="Resumen">
                        <field name="accepted_line_count" readonly="1"/>
                        <field name="completed_line_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Líneas del plan" name="lines">
                            <field name="line_ids" context="{'default_dentist_id': dentist_id, 'default_currency_id': currency_id}">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="phase"/>
                                    <field name="priority"/>
                                    <field name="treatment_code" optional="hide"/>
                                    <field name="treatment_name"/>
                                    <field name="tooth_code"/>
                                    <field name="odontogram_line_id" optional="hide"
                                           domain="[('odontogram_id.patient_id', '=', parent.patient_id)]"/>
                                    <field name="surface_codes" optional="hide"/>
                                    <field name="qty"/>
                                    <field name="estimated_unit_price"/>
                                    <field name="estimated_subtotal" readonly="1"/>
                                    <field name="state"/>
                                    <field name="is_accepted"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Resumen clínico" name="clinical">
                            <group>
                                <field name="chief_complaint" colspan="2" nolabel="1"/>
                                <field name="clinical_summary" colspan="2" nolabel="1"/>
                                <field name="observations" colspan="2" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Notas" name="notes">
                            <field name="notes" colspan="2" nolabel="1" widget="html"/>
                        </page>
                        <page string="Aprobación" name="approval">
                            <group>
                                <field name="patient_approved" readonly="1"/>
                                <field name="patient_approval_date" readonly="1"/>
                                <field name="approved_by_user_id" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_df_dental_treatment_plan_search" model="ir.ui.view">
        <field name="name">df.dental.treatment.plan.search</field>
        <field name="model">df.dental.treatment.plan</field>
        <field name="arch" type="xml">
            <search string="Planes">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="dentist_id"/>
                <filter name="f_draft" string="Borrador" domain="[('state', '=', 'draft')]"/>
                <filter name="f_progress" string="En ejecución" domain="[('state', '=', 'in_progress')]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="g_patient" string="Paciente" context="{'group_by': 'patient_id'}"/>
                    <filter name="g_state" string="Estado" context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_df_dental_treatment_plan" model="ir.actions.act_window">
        <field name="name">Planes de tratamiento</field>
        <field name="res_model">df.dental.treatment.plan</field>
        <field name="view_mode">tree,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">Cree un plan de tratamiento para el paciente.</p>
        </field>
    </record>
</odoo>
