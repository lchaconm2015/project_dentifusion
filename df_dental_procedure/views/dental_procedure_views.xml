<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_df_dental_procedure_tree" model="ir.ui.view">
        <field name="name">df.dental.procedure.tree</field>
        <field name="model">df.dental.procedure</field>
        <field name="arch" type="xml">
            <tree string="Procedimientos" decoration-muted="state=='cancelled'">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="procedure_name"/>
                <field name="tooth_code"/>
                <field name="dentist_id"/>
                <field name="encounter_id" optional="show"/>
                <field name="state"/>
                <field name="planned_date" optional="hide"/>
                <field name="performed_date" optional="hide"/>
            </tree>
        </field>
    </record>

    <record id="view_df_dental_procedure_form" model="ir.ui.view">
        <field name="name">df.dental.procedure.form</field>
        <field name="model">df.dental.procedure</field>
        <field name="arch" type="xml">
            <form string="Procedimiento clínico">
                <header>
                    <button name="action_plan" string="Planificar" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'draft')]}"/>
                    <button name="action_ready" string="Marcar listo" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', '!=', 'planned')]}"/>
                    <button name="action_start" string="Iniciar" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'not in', ('planned', 'ready'))]}"/>
                    <button name="action_performed" string="Realizado" type="object" class="btn-primary"
                            attrs="{'invisible': [('state', 'not in', ('draft', 'planned', 'ready', 'in_progress'))]}"/>
                    <button name="action_cancel" string="Cancelar" type="object" class="btn-secondary"
                            attrs="{'invisible': [('state', 'in', ('performed', 'cancelled'))]}"/>
                    <button name="action_validate" string="Validar" type="object" class="btn-secondary"
                            attrs="{'invisible': ['|', ('state', '!=', 'performed'), ('is_validated', '=', True)]}"/>
                    <button name="action_open_encounter" string="Encuentro" type="object" class="btn-secondary"
                            attrs="{'invisible': [('encounter_id', '=', False)]}"/>
                    <button name="action_open_treatment_plan" string="Plan" type="object" class="btn-secondary"
                            attrs="{'invisible': [('treatment_plan_id', '=', False)]}"/>
                    <button name="action_open_patient" string="Paciente" type="object" class="btn-secondary"/>
                    <button name="action_open_odontogram" string="Odontograma" type="object" class="btn-secondary"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,planned,ready,in_progress,performed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="General">
                            <field name="patient_id" options="{'no_create_edit': True}"/>
                            <field name="dentist_id"/>
                            <field name="assistant_id"/>
                            <field name="encounter_id" options="{'no_create_edit': True}"/>
                            <field name="appointment_id" readonly="1"/>
                            <field name="treatment_plan_id" options="{'no_create_edit': True}"/>
                            <field name="treatment_plan_line_id" options="{'no_create_edit': True}"
                                   domain="[('plan_id', '=', treatment_plan_id)]"
                                   attrs="{'invisible': [('treatment_plan_id', '=', False)]}"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Procedimiento">
                            <field name="procedure_code"/>
                            <field name="procedure_name"/>
                            <field name="procedure_category"/>
                            <field name="tooth_code"/>
                            <field name="surface_codes"/>
                            <field name="quadrant"/>
                            <field name="odontogram_line_id"
                                   domain="[('odontogram_id.patient_id', '=', patient_id)]"
                                   attrs="{'invisible': [('patient_id', '=', False)]}"/>
                        </group>
                    </group>
                    <group string="Honorarios">
                        <field name="currency_id"/>
                        <field name="estimated_fee"/>
                        <field name="actual_fee"/>
                    </group>
                    <notebook>
                        <page string="Ejecución clínica" name="clinical">
                            <group>
                                <field name="planned_date"/>
                                <field name="date_start"/>
                                <field name="date_end"/>
                                <field name="duration_minutes" readonly="1"/>
                                <field name="performed_date"/>
                            </group>
                            <group string="Resultado">
                                <field name="clinical_result" colspan="2" nolabel="1"/>
                                <field name="complications" colspan="2" nolabel="1"/>
                                <field name="post_op_instructions" colspan="2" nolabel="1"/>
                            </group>
                            <group string="Descripción">
                                <field name="description" colspan="2" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Voz / IA" name="voice">
                            <group>
                                <field name="data_source"/>
                                <field name="voice_transcript" colspan="2" nolabel="1"/>
                                <field name="ai_summary" colspan="2" nolabel="1"/>
                            </group>
                        </page>
                        <page string="Validación" name="validation">
                            <group>
                                <field name="is_validated" readonly="1"/>
                                <field name="validated_by" readonly="1"/>
                                <field name="validated_datetime" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_df_dental_procedure_search" model="ir.ui.view">
        <field name="name">df.dental.procedure.search</field>
        <field name="model">df.dental.procedure</field>
        <field name="arch" type="xml">
            <search string="Procedimientos">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="procedure_name"/>
                <field name="dentist_id"/>
                <filter name="f_performed" string="Realizados" domain="[('state', '=', 'performed')]"/>
                <filter name="f_open" string="Abiertos" domain="[('state', 'not in', ('performed', 'cancelled'))]"/>
            </search>
        </field>
    </record>

    <record id="action_df_dental_procedure" model="ir.actions.act_window">
        <field name="name">Procedimientos clínicos</field>
        <field name="res_model">df.dental.procedure</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
